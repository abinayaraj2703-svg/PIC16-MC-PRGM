// PIC16F877A Configuration Bit Settings
#pragma config FOSC = HS        // Oscillator Selection (HS oscillator)
#pragma config WDTE = OFF       // Watchdog Timer Enable (WDT disabled)
#pragma config PWRTE = OFF      // Power-up Timer Enable (PWRT disabled)
#pragma config BOREN = ON       // Brown-out Reset Enable (BOR enabled)
#pragma config LVP = OFF        // Low-Voltage Programming Enable (Disabled)
#pragma config CPD = OFF        // Data EEPROM Memory Code Protection (Disabled)
#pragma config WRT = OFF        // Flash Program Memory Write Enable (Disabled)
#pragma config CP = OFF         // Flash Program Memory Code Protection (Disabled)

#include <xc.h>

#define _XTAL_FREQ 20000000 // 20 MHz crystal

// Function to ensure the I2C bus is completely idle
void I2C_Wait() {
    // Wait until R/W bit is 0 AND the lower 5 bits of SSPCON2 are 0
    // This ensures no Start, Stop, Receive, or Acknowledge sequences are active
    while ((SSPSTAT & 0x04) || (SSPCON2 & 0x1F));
}

void I2C_Init(const unsigned long c) {
    SSPCON = 0b00101000;           // I2C Master mode, clock = FOSC/(4 * (SSPADD + 1))
    SSPCON2 = 0;
    SSPADD = (_XTAL_FREQ/(4*c))-1; // Calculate baud rate
    SSPSTAT = 0;
    TRISC3 = 1; TRISC4 = 1;        // SCL and SDA must be set as inputs for I2C
}

void I2C_Start() {
    I2C_Wait();
    SSPCON2bits.SEN = 1;           // Initiate Start condition
}

void I2C_Stop() {
    I2C_Wait();
    SSPCON2bits.PEN = 1;           // Initiate Stop condition
}

void I2C_Write(unsigned char data) {
    I2C_Wait();
    SSPBUF = data;                 // Load data into the buffer to start transmission
    while(SSPSTATbits.R_nW);       // Wait for the transmission to physically complete on the bus
    
    // Note: We removed the infinite ACKSTAT loop here so the code continues 
    // even if the Proteus debugger (or a missing slave) doesn't ACK.
}

void main() {
    I2C_Init(100000);              // 100kHz standard mode
    
    while(1) {
        I2C_Start();               // Send Start
        I2C_Write(0xA0);           // Send Slave Address + Write Bit (0)
        I2C_Write('I');            // Send data payload
        I2C_Stop();                // Send Stop
        
        __delay_ms(1000);          // Wait 1 second
    }
}
